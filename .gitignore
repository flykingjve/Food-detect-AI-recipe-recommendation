# ── 機密：API 金鑰，切勿提交 ──────────────────────────
.env

# ── 資料集（龐大，不上傳；由 Roboflow 另行下載）───────
train/
valid/
test/

# ── 虛擬環境 ─────────────────────────────────────────
venv/
setup/venv/
.venv/

# ── 訓練 / 推論輸出 ──────────────────────────────────
runs/
preview/

# ── 模型權重：忽略所有 .pt，但保留訓練成果 best.pt ───
# （yolo11n.pt / yolo11s.pt / yolo26n.pt 為可重新下載的預訓練基底模型）
*.pt
!weights/best.pt

# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/

# ── 暫存 / 系統 ──────────────────────────────────────
_*.log
_*.err
_*.py
.DS_Store
Thumbs.db
